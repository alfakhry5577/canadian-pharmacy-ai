# Copy this file to .env and fill in real values for production.

ENV=development

# Local dev default (zero config). For production use PostgreSQL, e.g.:
# DATABASE_URL=postgresql+psycopg2://roshetta_user:CHANGE_ME@localhost:5432/roshetta
DATABASE_URL=sqlite:///./roshetta.db

# Generate a long random string for production, e.g.: openssl rand -hex 32
JWT_SECRET_KEY=CHANGE_ME_IN_PRODUCTION_USE_A_LONG_RANDOM_SECRET
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=720

TESSERACT_LANGS=ara+eng

# Leave empty to run the AI service in offline mock mode.
ANTHROPIC_API_KEY=
AI_MODEL=claude-sonnet-4-6

UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=10

ALLOWED_ORIGINS=["http://localhost:3000"]
