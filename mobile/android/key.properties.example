# Copy this file to android/key.properties (same directory) and fill in your
# real release keystore details. NEVER commit the real key.properties or the
# .jks/.keystore file — both are gitignored.
#
# Generate a keystore first (see mobile/README.md "Release Build Instructions"):
#   keytool -genkey -v -keystore upload-keystore.jks -keyalg RSA -keysize 2048 \
#     -validity 10000 -alias upload

storePassword=CHANGE_ME
keyPassword=CHANGE_ME
keyAlias=upload
storeFile=/absolute/path/to/upload-keystore.jks
