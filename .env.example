# Copy to .env at the project root before running `docker compose up`

POSTGRES_USER=roshetta_user
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=roshetta

JWT_SECRET_KEY=change_me_to_a_long_random_secret

# Leave empty to run the AI service in offline mock mode (see backend/app/services/ai_service.py)
ANTHROPIC_API_KEY=
AI_MODEL=claude-sonnet-4-6

NEXT_PUBLIC_API_URL=http://localhost:8000
